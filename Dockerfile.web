# Multi-stage Dockerfile - Rankify Next.js Frontend

FROM node:22-alpine AS builder
WORKDIR /app

# Copy only package files, NOT node_modules or pnpm-store
COPY package.json package-lock.json* ./
COPY apps/web/package.json ./apps/web/

# Clean install (fresh node_modules, no pnpm artifacts)
RUN rm -rf node_modules .pnpm-store && npm ci

# Build Next.js
WORKDIR /app/apps/web
RUN npm ci
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# Copy source after install (for any runtime needs)
WORKDIR /app
COPY . .

FROM node:22-alpine
WORKDIR /app

# Copy ONLY built app and dependencies from builder
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=builder /app/apps/web/.next ./apps/web/.next
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder /app/package.json ./
COPY --from=builder /app/apps/web/package.json ./apps/web/

EXPOSE 3000
ENV NODE_ENV=production
ENV PORT=3000

WORKDIR /app/apps/web
CMD ["npm", "start"]
