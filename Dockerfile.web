# Multi-stage Dockerfile - Rankify Next.js Frontend

FROM node:22-alpine AS builder
WORKDIR /app
COPY . .
RUN npm install
WORKDIR /app/apps/web
RUN npm install
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM node:22-alpine
WORKDIR /app
COPY --from=builder /app .

EXPOSE 3000
ENV NODE_ENV=production
ENV PORT=3000

WORKDIR /app/apps/web
CMD ["npm", "start"]
