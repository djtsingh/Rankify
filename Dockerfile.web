# Multi-stage Dockerfile - Rankify Next.js Frontend
# Properly debug build paths to resolve Next.js issue

FROM node:22-alpine AS builder
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@latest

# Copy ALL lockfiles and package definitions
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY apps/web/package.json ./apps/web/

# Install dependencies using pnpm (respects lock file exactly)
RUN pnpm install --frozen-lockfile

# Build Next.js
WORKDIR /app/apps/web
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
# Output directory contents before build
RUN echo "DEBUG: Directory contents before build" && ls -R /app/apps/web/src && pnpm run build

FROM node:22-alpine
WORKDIR /app

# Install pnpm in runtime (minimal, for npm start only)
RUN npm install -g pnpm@latest

# Copy built app and node_modules from builder
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/.pnpm ./pnpm
COPY --from=builder /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=builder /app/apps/web/.next ./apps/web/.next
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder /app/package.json ./
COPY --from=builder /app/apps/web/package.json ./apps/web/

EXPOSE 3000
ENV NODE_ENV=production
ENV PORT=3000

WORKDIR /app/apps/web
CMD ["npm", "start"]
