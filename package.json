{
  "name": "rankify-monorepo",
  "version": "1.0.0",
  "description": "Rankify - SEO Made Simple",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "cd api && func start",
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:api\"",
    "build:web": "pnpm --filter web build",
    "build:api": "cd api && npm run build",
    "build": "pnpm build:web && pnpm build:api"
  },
  "keywords": ["seo", "analytics", "saas"],
  "author": "djtsingh",
  "license": "Proprietary",
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "prettier": "^3.1.1"
  }
}
